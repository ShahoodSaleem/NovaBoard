{
  "manifest_version": 3,
  "name": "NovaBoard",
  "version": "1.0.0",
  "description": "A premium, AI-ready kanban-style new tab bookmark manager.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "unlimitedStorage",
    "bookmarks",
    "favicon",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Quick Save to NovaBoard Inbox"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to NovaBoard"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },
  "icons": {
    "16": "assets/logo.gif",
    "48": "assets/logo.gif",
    "128": "assets/logo.gif"
  }
}
